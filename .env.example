# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smrh_db
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Bcrypt
BCRYPT_ROUNDS=12

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seminario@cristorei.ao
SMTP_PASS=your_email_password
EMAIL_FROM=Seminário Cristo Rei <noreply@cristorei.ao>

# Frontend URL (for CORS + redirect)
FRONTEND_URL=http://localhost:5173

# Encryption key for sensitive data (NIF, etc.) - 32 bytes hex
ENCRYPTION_KEY=your_32_byte_hex_key_here

# File uploads
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads
